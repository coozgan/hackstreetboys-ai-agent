# Google Cloud project configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Optional: enable telemetry
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true

# MCP Server URL — set to your deployed Cloud Run URL after deploying mcp-server
# Leave unset or use the default (http://localhost:3000) for local development
# MCP_SERVER_URL=https://mcp-server-XXXXXXXXXX.us-central1.run.app

# Shop Agent URL — set to your deployed Cloud Run URL after deploying shop-agent
# Leave unset or use the default (http://localhost:8001) for local development
# SHOP_AGENT_URL=https://shop-agent-XXXXXXXXXX.us-central1.run.app

# LLM model (optional, defaults to gemini-2.5-flash)
# AGENT_MODEL=gemini-2.5-flash

# Session persistence (optional — defaults to local SQLite)
# Set to your Agent Engine resource URI after deploying the Personal AI
# SESSION_SERVICE_URI=agentengine://projects/YOUR_PROJECT/locations/us-central1/reasoningEngines/YOUR_ENGINE_ID

# SQLite database path (optional, defaults to data/hackstreetboys.db)
# HACKSTREETBOYS_DB_PATH=data/hackstreetboys.db
